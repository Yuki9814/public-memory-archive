{
  "name": "public-memory-archive",
  "private": true,
  "version": "0.1.0",
  "description": "A restrained public-event evidence archive with traceable sources, revision history, and moderation workflows.",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,worker,web \"pnpm:dev:api\" \"pnpm:dev:worker\" \"pnpm:dev:web\"",
    "dev:api": "pnpm --filter @memory-archive/api run dev",
    "dev:worker": "pnpm --filter @memory-archive/worker run dev",
    "dev:web": "pnpm --filter @memory-archive/web run dev",
    "build": "pnpm run db:generate && pnpm -r run build",
    "test": "tsx --test packages/shared/src/*.test.ts apps/api/src/lib/*.test.ts",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/src/seed.ts",
    "openapi": "pnpm --filter @memory-archive/api run openapi",
    "lint": "tsc -b --pretty"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
